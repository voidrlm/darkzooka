{
    "manifest_version": 3,
    "name": "Darkzooka",
    "description": "Pick any element and blast it into dark mode.",
    "version": "1.0.0",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": ["<all_urls>"],
    "content_scripts": [
        {
            "js": ["content.js"],
            "matches": ["http://*/*", "https://*/*"],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["src/content/*", "src/shared/*"],
            "matches": ["<all_urls>"]
        }
    ]
}
